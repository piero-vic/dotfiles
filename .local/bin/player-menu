#!/usr/bin/env bash

# Requirements:
# rofi https://github.com/lbonn/rofi
# playerctl https://github.com/altdesktop/playerctl
# mako https://github.com/emersion/mako

app_name="player-menu"

if ! playerctl status >/dev/null 2>&1; then
  notify-send -a "$app_name" "No players found" --urgency=low
  exit 0
fi

available_players=$(playerctl -l)

if [ "$(echo "$available_players" | wc -l)" -gt 1 ]; then
  player=$(echo "$available_players" | rofi -sync -dmenu -i -p "Select player")
else
  player=$available_players
fi

if [[ -z $player ]]; then
  exit 0
fi

if metadata=$(playerctl --player="$player" metadata 2>&1); then
  title=$(echo "$metadata" | grep -oP 'xesam:title\s+\K.+')
  artist=$(echo "$metadata" | grep -oP 'xesam:artist\s+\K.+')
  artUrl=$(echo "$metadata" | grep -oP 'mpris:artUrl\s+\K.+')

  if [[ -n $title ]]; then
    notification_id=$(
      notify-send -p -t 0 -a "$app_name" ${artUrl:+-i "$artUrl"} "$title" "$artist"
    )
  fi
fi

case $(
  rofi -sync -dmenu -i -p "Player" <<EOF
|||>Play/Pause
   Stop
<|| Prev
||> Next
   Loop
   Shuffle
EOF
) in
"|||>Play/Pause")
  playerctl --player="$player" play-pause
  ;;
"   Stop")
  playerctl --player="$player" stop
  ;;
"<|| Prev")
  playerctl --player="$player" previous
  ;;
"||> Next")
  playerctl --player="$player" next
  ;;
"   Loop")
  loop_status=$(playerctl --player="$player" loop)
  if [[ -n $loop_status ]]; then
    loop_status=$(printf 'none\nplaylist\ntrack' | rofi -sync -dmenu -i -p "  Loop: $loop_status")
    playerctl --player="$player" loop "$loop_status" &&
      notify-send -a "$app_name" "Player loop is set to $loop_status"
  else
    notify-send -a "$app_name" "Player cannot handle loop" --urgency=critical
  fi
  ;;
"   Shuffle")
  case $(playerctl --player="$player" shuffle) in
  "On")
    playerctl --player="$player" shuffle off &&
      notify-send -a "$app_name" "Player shuffle is off"
    ;;
  "Off")
    playerctl --player="$player" shuffle on &&
      notify-send -a "$app_name" "Player shuffle is on"
    ;;
  *)
    notify-send -a "$app_name" "Player cannot handle shuffle" --urgency=critical
    ;;
  esac
  ;;
esac

if [[ -n $notification_id ]]; then
  makoctl dismiss -n "$notification_id" 2>/dev/null
fi
