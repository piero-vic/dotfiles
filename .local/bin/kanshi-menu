#!/usr/bin/env bash

# Requirements:
# kanshi https://sr.ht/~emersion/kanshi/
# rofi https://github.com/davatorium/rofi
# mako https://github.com/emersion/mako

config="${XDG_CONFIG_HOME:-$HOME/.config}/kanshi/config"

choice=$(
  grep -oP '^profile\s+\K[^ ]+' "$config" |
    rofi -dmenu -i -p "Kanshi" -no-custom
)
if [ -z "$choice" ]; then
  exit 0
fi

err=$({ kanshictl switch "$choice" 2>&1 1>&3; } 3>&1)
if [ -n "$err" ]; then
  notify-send -a "kanshi" "Kanshi" "$err" --urgency=low
else
  notify-send -a "kanshi" "Kanshi" "Switching to profile: $choice"
fi
