#!/usr/bin/env bash

# Requirements:
# hyprpicker https://github.com/hyprwm/hyprpicker
# imagemagick https://github.com/ImageMagick/ImageMagick
# mako https://github.com/emersion/mako
# wl-clipboard https://github.com/bugaevc/wl-clipboard

app_name="colorpicker"
notify_icon="/tmp/colorpicker.jpg"

hex=$(hyprpicker)
if [[ -z $hex ]]; then
  notify-send -a "$app_name" " Color Picker" "Selection cancelled"
  exit 0
fi

wl-copy "$hex" &&
  magick -size 50x50 "xc:$hex" "$notify_icon" &&
  notify-send -i "$notify_icon" -a "$app_name" " $hex" "Copied to clipboard"
