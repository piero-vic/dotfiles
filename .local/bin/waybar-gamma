#!/usr/bin/env bash

# Requirements:
# mako https://github.com/emersion/mako
# wlsunset https://sr.ht/~kennylevinsen/wlsunset/

app_name="waybar-gamma"

if [[ "$1" == "toggle" ]]; then
  if pidof wlsunset >/dev/null 2>&1; then
    kill -9 "$(pidof wlsunset)"
    notify-send -a "$app_name" -t 1000 'Day/Night Gamma' "󰹏 Turning Off"
  else
    wlsunset -l -12 -L -77 >/dev/null 2>&1 &
    notify-send -a "$app_name" -t 1000 'Day/Night Gamma' "󱩌 Turning On"
  fi

  pkill -SIGRTMIN+8 waybar
  exit 0
fi

if pidof wlsunset >/dev/null 2>&1; then
  echo -n '{ "text": "activated", "tooltip": "activated", "alt": "activated", "class": "activated" }'
else
  echo -n '{ "text": "deactivated", "tooltip": "deactivated", "alt": "deactivated", "class": "deactivated" }'
fi
