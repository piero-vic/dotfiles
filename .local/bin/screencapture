#!/usr/bin/env bash

# Requirements:
# rofi https://github.com/lbonn/rofi
# grim https://git.sr.ht/~emersion/grim
# jq https://github.com/jqlang/jq
# mako https://github.com/emersion/mako
# satty https://github.com/Satty-org/Satty
# slurp https://github.com/emersion/slurp

screenshots_directory=~/pictures/screenshots
filename="$screenshots_directory/$(date '+%Y%m%d_%Hh%Mm%Ss')_grim.png"

[[ -d $screenshots_directory ]] || mkdir -p $screenshots_directory

get_screen() {
  grim - | satty --filename - --output-filename "$filename"
}

get_window() {
  region="$(
    swaymsg -t get_tree |
      jq -r '.. | select(.focused?) | select(.type == "con") | .rect | "\(.x),\(.y) \(.width)x\(.height)"'
  )"
  if [[ -z "$region" ]]; then
    notify-send "󰄀 Grim" "No window in workspace"
    exit 0
  fi

  grim -g "$region" - | satty --filename - --output-filename "$filename"
}

get_section() {
  region="$(slurp 2>&1)"
  if [[ "$region" == "selection cancelled" ]]; then
    notify-send "󰄀 Grim" "Selection cancelled"
    exit 0
  fi

  grim -g "$region" - | satty --filename - --output-filename "$filename"
}

case $(
  rofi -sync -dmenu -i -p "Screencapture" <<EOF
Screen
Window
Selection
Color
EOF
) in
"Screen")
  get_screen
  ;;
"Window")
  get_window
  ;;
"Selection")
  get_section
  ;;
"Color")
  colorpicker
  ;;
esac
